{
  "name": "personal-blog-content",
  "private": true,
  "scripts": {
    "postinstall": "cd engine && npm install",
    "dev": "cd engine && npm run dev",
    "build": "cd engine && npm run build",
    "preview": "cd engine && npm run preview",
    "check": "cd engine && npm run check",
    "deploy": "npx wrangler pages deploy ./engine/dist --project-name=personal-blog",
    "deploy:prod": "npx wrangler pages deploy ./engine/dist --project-name=personal-blog --branch=main",
    "deploy:preview": "wnpx rangler pages deploy ./engine/dist --project-name=personal-blog --branch=preview"
  }
}
